{
  "name": "inbill",
  "version": "2.0.3",
  "description": "InBill — Universal ERP for Billing, Inventory & Business Management",
  "author": "InBill Solutions",
  "private": true,
  "main": "main/main.js",
  "scripts": {
    "next-dev": "next dev -p 3456",
    "next-build": "next build",
    "qa-frontend": "node tests/frontend-contract.mjs",
    "qa-e2e": "node tests/run-e2e-core.cjs",
    "qa-financial-integrity": "node tests/run-financial-integrity.cjs",
    "qa-state-consistency": "node tests/run-report-dashboard-consistency.cjs",
    "qa-runtime": "node tests/run-electron-runtime-smoke.cjs",
    "qa-regression": "node tests/frontend-contract.mjs && node tests/run-e2e-core.cjs && node tests/run-financial-integrity.cjs && node tests/run-report-dashboard-consistency.cjs && node tests/run-electron-runtime-smoke.cjs",
    "electron-dev": "wait-on http://localhost:3456 && electron .",
    "dev": "concurrently \"npm run next-dev\" \"npm run electron-dev\"",
    "build": "next build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-is-dev": "^3.0.1",
    "lucide-react": "^1.14.0",
    "next": "^15.3.1",
    "postgres": "^3.4.9",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.inbill.erp",
    "productName": "InBill Professional ERP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/inbill.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "better-sqlite3"
      }
    ]
  }
}
